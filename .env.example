# Hosted API (Railway) — default for dev & production
NEXT_PUBLIC_API_URL=https://driveclearbackend-production.up.railway.app/api/v1

# Local backend only (run DriveClear_Backend on port 8000)
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Firebase Web App config (Firebase Console → Project settings → Your apps → Web)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Dev only: must match Firebase Console → Phone → Phone numbers for testing
NEXT_PUBLIC_FIREBASE_TEST_PHONE=9876543210
NEXT_PUBLIC_FIREBASE_TEST_OTP=123456

# Must match backend API_PAYLOAD_ENCRYPTION_* when enabled on Render
NEXT_PUBLIC_API_PAYLOAD_ENCRYPTION_ENABLED=false
NEXT_PUBLIC_API_PAYLOAD_ENCRYPTION_KEY=
